generator client {
    provider = "prisma-client"
    output   = "./generated"
}

datasource db {
    provider = "postgresql"
}

//
// ENUMS
//

enum ThemeMode {
    light
    dark
    system
}

enum UserRole {
    admin
    customer
}

enum UserStatus {
    pending
    active
    suspended
}

enum OtpPurpose {
    setPassword
    resetPassword
    updatePassword
    verifyIdentifier
    updateIdentifier
    enableMfa
    disableMfa
    updateMfa
    verifyMfa
}

enum OtpType {
    numericCode
    secureToken
}

enum MfaMethod {
    email
    sms
    whatsapp
    authApp
}

enum SessionStatus {
    active
    revoked
    expired
}

enum AuditAction {
    create
    update
    delete
    login
    logout
    statusChange
}

enum PushProvider {
    fcm
    expo
}

enum NotificationChannel {
    push
    email
    sms
    whatsapp
}

enum NotificationStatus {
    pending
    partial
    sent
    failed
}

enum NotificationPurpose {
    signUp
    signIn
    verifyMfa
    updateMfa
    updatePassword
    verifyIdentifier
    updateIdentifier
    userStatus
    securityAlert
}

enum MediaType {
    avatar
    other
}

enum MediaVisibility {
    private
    public
}

//
// AUTH MODELS
//

model User {
    // Core fields
    id String @id @default(ulid())

    avatarId String?
    avatar   Media?  @relation("UserAvatar", fields: [avatarId], references: [id])

    firstName   String
    lastName    String?
    displayName String
    password    String? @db.VarChar(255)

    // Contact info
    email           String? @unique @db.VarChar(255)
    phone           String? @unique @db.VarChar(20)
    isEmailVerified Boolean @default(false)
    isPhoneVerified Boolean @default(false)

    role   UserRole
    status UserStatus @default(pending)

    preferredTheme    ThemeMode @default(system)
    pushNotifications Boolean   @default(false)

    preferredMfa MfaMethod?
    loginAlerts  Boolean    @default(true)
    lastLoginAt  DateTime?

    // Meta
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Relations
    otps          Otp[]
    sessions      Session[]
    notifications Notification[]
    auditLogs     AuditLog[]

    medias Media[] @relation("UserUploads")

    // Indexes
    @@index([status])
    @@index([role])
    @@index([email, isEmailVerified])
    @@index([phone, isPhoneVerified])
    @@index([deletedAt])
}

//
// SYSTEM
//

model Session {
    id String @id @default(ulid())

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    refreshTokenHash String
    status           SessionStatus @default(active)

    ip       String
    location String
    isp      String?
    timezone String

    deviceId   String
    deviceType String
    deviceInfo String

    isTrusted  Boolean   @default(false)
    lastSeenAt DateTime?

    pushProvider PushProvider?
    pushToken    String?

    createdAt DateTime  @default(now())
    expiresAt DateTime
    revokedAt DateTime?

    @@unique([userId, deviceId])
    @@index([expiresAt])
    @@index([userId, status])
    @@index([expiresAt, status])
}

model Otp {
    id String @id @default(ulid())

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    purpose OtpPurpose
    type    OtpType    @default(numericCode)
    secret  String
    meta    Json?

    expiresAt DateTime
    usedAt    DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    @@index([userId, purpose])
    @@index([expiresAt])
}

model AuditLog {
    id String @id @default(ulid())

    userId String?
    user   User?   @relation(fields: [userId], references: [id])

    action AuditAction

    entityType String
    entityId   String

    meta Json?

    ip        String?
    userAgent String?

    createdAt DateTime @default(now())

    @@index([userId])
    @@index([entityType, entityId])
    @@index([createdAt])
}

model Notification {
    id String @id @default(ulid())

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    title     String
    message   String
    recipient String
    meta      Json?

    purpose  NotificationPurpose
    channels NotificationChannel[]
    status   NotificationStatus    @default(pending)

    readAt    DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    @@index([userId, readAt])
}

model Media {
    id String @id @default(ulid())

    uploadedById String
    uploadedBy   User   @relation("UserUploads", fields: [uploadedById], references: [id])

    publicId     String @unique
    url          String @unique
    mimeType     String
    resourceType String
    size         Int
    hash         String @unique

    name       String
    altText    String?
    type       MediaType
    visibility MediaVisibility @default(private)
    notes      String?

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    users User[] @relation("UserAvatar")

    @@index([name])
    @@index([type])
    @@index([uploadedById])
    @@index([createdAt])
    @@index([deletedAt])
}
