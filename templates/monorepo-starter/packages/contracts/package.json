{
  "name": "@workspace/contracts",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "license": "ISC",
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./auth": {
      "import": "./dist/auth.js",
      "types": "./dist/auth.d.ts"
    },
    "./user": {
      "import": "./dist/user.js",
      "types": "./dist/user.d.ts"
    },
    "./admin": {
      "import": "./dist/admin.js",
      "types": "./dist/admin.d.ts"
    },
    "./audit": {
      "import": "./dist/audit.js",
      "types": "./dist/audit.d.ts"
    },
    "./business": {
      "import": "./dist/business.js",
      "types": "./dist/business.d.ts"
    },
    "./dashboard": {
      "import": "./dist/dashboard.js",
      "types": "./dist/dashboard.d.ts"
    },
    "./media": {
      "import": "./dist/media.js",
      "types": "./dist/media.d.ts"
    },
    "./notification": {
      "import": "./dist/notification.js",
      "types": "./dist/notification.d.ts"
    },
    "./lead": {
      "import": "./dist/lead.js",
      "types": "./dist/lead.d.ts"
    },
    "./traffic": {
      "import": "./dist/traffic.js",
      "types": "./dist/traffic.d.ts"
    }
  },
  "dependencies": {
    "nestjs-zod": "^5.1.1",
    "zod": "^4.3.6",
    "@workspace/db": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@workspace/config": "workspace:*",
    "eslint": "^9.39.3",
    "react": "^19.2.4",
    "tsup": "^8.5.1"
  }
}
