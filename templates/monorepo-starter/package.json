{
  "name": "zhx-monorepo",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:packages": "turbo run build --filter=@workspace/*",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "check-types": "turbo check-types",
    "format": "turbo format",
    "update:deps": "pnpm update -r"
  },
  "devDependencies": {
    "@workspace/config": "workspace:*",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "turbo": "^2.8.13",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.25.10"
    },
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "@tailwindcss/oxide",
      "argon2",
      "core-js-pure",
      "esbuild",
      "msw",
      "prisma",
      "protobufjs",
      "puppeteer",
      "sharp",
      "unrs-resolver"
    ]
  }
}
