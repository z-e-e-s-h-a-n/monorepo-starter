{
  "name": "zhx-monorepo",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "format": "turbo format",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "update:deps": "pnpm update -r",
    "check-types": "turbo check-types",
    "build:web": "turbo build --filter=web",
    "start:web": "cd apps/web && pnpm start",
    "build:dashboard": "turbo build --filter=dashboard",
    "start:dashboard": "cd apps/dashboard && pnpm start",
    "build:server": "turbo build --filter=server",
    "start:server": "cd server && pnpm start",
    "build:packages": "turbo build --filter=@workspace/*",
    "prune:server": "turbo prune server --docker"
  },
  "devDependencies": {
    "@workspace/config": "workspace:*",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "turbo": "^2.8.13",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.25.10"
    },
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "@tailwindcss/oxide",
      "argon2",
      "core-js-pure",
      "esbuild",
      "msw",
      "prisma",
      "protobufjs",
      "puppeteer",
      "sharp",
      "unrs-resolver"
    ]
  }
}
