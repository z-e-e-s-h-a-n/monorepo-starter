{
  "name": "server",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "tsup src/main.ts --watch",
    "start": "node dist/main.js",
    "build": "tsup",
    "lint": "eslint",
    "check-types": "tsc --noEmit",
    "format": "prettier --write \"{src,apps,libs,test}/**/*.ts\"",
    "generate:module": "bash ./scripts/gen-module.sh",
    "admin:bootstrap": "tsx ./scripts/admin-bootstrap.ts",
    "prisma:generate": "pnpm --filter @workspace/db prisma:generate && tsx ./scripts/gen-soft-delete",
    "prisma:migrate": "pnpm --filter @workspace/db prisma:migrate",
    "prisma:deploy": "pnpm --filter @workspace/db prisma:deploy",
    "prisma:studio": "pnpm --filter @workspace/db prisma:studio",
    "prisma:validate": "pnpm --filter @workspace/db prisma:validate",
    "prisma:reset": "pnpm --filter @workspace/db prisma:reset",
    "prisma:seed": "pnpm --filter @workspace/db prisma:seed",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@keyv/redis": "^5.1.6",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/schedule": "^6.1.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "argon2": "^0.44.0",
    "axios": "^1.13.6",
    "cache-manager": "^7.2.8",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "firebase-admin": "^13.7.0",
    "jose": "^6.2.0",
    "lodash": "^4.17.23",
    "ms": "^2.1.3",
    "nest-winston": "^1.10.2",
    "nestjs-zod": "^5.1.1",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "streamifier": "^0.1.1",
    "twilio": "^5.12.2",
    "ua-parser-js": "^2.0.9",
    "ulid": "^3.0.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.16",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.18",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/ms": "^2.1.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.5",
    "@types/nodemailer": "^7.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-facebook": "^3.0.4",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.18.0",
    "@types/streamifier": "^0.1.2",
    "@types/supertest": "^6.0.3",
    "@workspace/config": "workspace:*",
    "@workspace/contracts": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/shared": "workspace:*",
    "@workspace/templates": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-turbo": "^2.8.13",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "prisma": "^7.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.56.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@/decorators/(.*)$": "<rootDir>/lib/decorators/$1",
      "^@/dto/(.*)$": "<rootDir>/lib/dto/$1",
      "^@/filters/(.*)$": "<rootDir>/lib/filters/$1",
      "^@/guards/(.*)$": "<rootDir>/lib/guards/$1",
      "^@/middleware/(.*)$": "<rootDir>/lib/middleware/$1",
      "^@/interceptors/(.*)$": "<rootDir>/lib/interceptors/$1",
      "^@/pipes/(.*)$": "<rootDir>/lib/pipes/$1",
      "^@/schemas/(.*)$": "<rootDir>/lib/schemas/$1",
      "^@/templates/(.*)$": "<rootDir>/lib/templates/$1",
      "^@/utils/(.*)$": "<rootDir>/lib/utils/$1",
      "^@/constants/(.*)$": "<rootDir>/lib/constants/$1",
      "^@workspace/shared/utils$": "<rootDir>/../../packages/shared/src/utils/index.ts",
      "^@workspace/shared/constants$": "<rootDir>/../../packages/shared/src/constants/index.ts",
      "^@workspace/db/client$": "<rootDir>/../../packages/db/src/client.ts",
      "^@/(.*)$": "<rootDir>/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
