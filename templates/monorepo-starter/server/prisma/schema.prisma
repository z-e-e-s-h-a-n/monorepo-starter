generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

//
// ENUMS
//

enum ThemeMode {
  light
  dark
  system
}

enum UserRole {
  admin
  customer
}

enum UserStatus {
  pending
  active
  suspended
}

enum OtpPurpose {
  authSetPassword
  authResetPassword
  authVerifyIdentifier
  authUpdateIdentifier
  authUpdateMfa
  authDisableMfa
  authVerifyMfa
}

enum OtpType {
  numericCode
  secureToken
}

enum MfaMethod {
  email
  sms
  whatsapp
  authApp
}

enum SessionStatus {
  active
  revoked
  expired
}

enum NotificationChannel {
  push
  email
  sms
  whatsapp
}

enum MessagingChannel {
  sms
  whatsapp
}

enum PushProvider {
  fcm
  expo
}

enum NotificationPurpose {
  authSignUp
  authSignIn
  authSetPassword
  authResetPassword
  authVerifyIdentifier
  authUpdateIdentifier
  authUpdateMfa
  authDisableMfa
  authVerifyMfa

  accountSuspended
  accountReactivated
}

enum NotificationPriority {
  normal
  important
}

enum NotificationStatus {
  pending
  partial
  sent
  failed
}

enum MediaVisibility {
  private
  public
}

enum MediaType {
  photo
  logo
  other
}

//
// AUTH MODELS
//

model User {
  // Core fields
  id          String  @id @default(ulid())
  firstName   String
  lastName    String?
  displayName String
  password    String? @db.VarChar(255)

  imageId String?
  image   Media?  @relation("UserImage", fields: [imageId], references: [id])

  // Contact info
  email           String? @unique @db.VarChar(255)
  phone           String? @unique @db.VarChar(20)
  isEmailVerified Boolean @default(false)
  isPhoneVerified Boolean @default(false)

  role   UserRole
  status UserStatus @default(pending)

  preferredTheme    ThemeMode @default(system)
  pushNotifications Boolean   @default(false)

  preferredMfa    MfaMethod?
  fallbackChannel MessagingChannel @default(sms)

  loginAlerts Boolean   @default(true)
  lastLoginAt DateTime?

  // Meta
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  otps          Otp[]
  sessions      Session[]
  notifications Notification[]
  medias        Media[]        @relation("UserUploads")

  // Indexes
  @@index([status])
  @@index([role])
  @@index([email, isEmailVerified])
  @@index([phone, isPhoneVerified])
  @@index([deletedAt])
}

model Session {
  id String @id @default(ulid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash String
  status           SessionStatus @default(active)

  ip       String
  location String
  isp      String?
  timezone String

  deviceId   String
  deviceType String
  deviceInfo String

  isTrusted  Boolean   @default(false)
  lastSeenAt DateTime?

  pushProvider PushProvider?
  pushToken    String?

  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  @@unique([userId, deviceId])
  @@index([expiresAt])
  @@index([userId, status])
  @@index([expiresAt, status])
}

model Otp {
  id        String     @id @default(ulid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose   OtpPurpose
  type      OtpType    @default(numericCode)
  secret    String
  meta      Json?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId, purpose])
  @@index([expiresAt])
}

model Notification {
  id     String @id @default(ulid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  purpose  NotificationPurpose
  channels NotificationChannel[]
  priority NotificationPriority  @default(normal)

  subject   String
  message   String
  recipient String
  meta      Json?

  status NotificationStatus @default(pending)

  readAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([status, createdAt])
}

model Media {
  id String @id @default(ulid())

  uploadedById String
  uploadedBy   User   @relation("UserUploads", fields: [uploadedById], references: [id])

  url      String @unique
  filename String
  mimeType String
  size     Int
  hash     String @unique

  title      String
  altText    String?
  type       MediaType
  visibility MediaVisibility @default(private)

  notes String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users User[] @relation("UserImage")

  @@index([type])
  @@index([filename])
  @@index([uploadedById])
  @@index([createdAt])
  @@index([deletedAt])
}
