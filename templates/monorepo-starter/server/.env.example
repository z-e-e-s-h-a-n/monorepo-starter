
# ==============================
# Mi MedCare Server
# ==============================
NODE_ENV="development"
APP_PORT="4000"
APP_ENDPOINT="http://localhost:4000"
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"
CLIENT_ENDPOINT="http://localhost:3000"
ADMIN_ENDPOINT="http://localhost:3001"

# ==============================
# Database
# ==============================
# Example: postgresql://postgres:password@localhost:5432/mi_medcare
DB_URI="postgresql://postgres:password@localhost:5432/mi_medcare"

# ==============================
# Media Storage
# ==============================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
CLOUDINARY_URL="cloudinary://your-cloudinary-api-key:your-cloudinary-api-secret@your-cloud-name"

# ==============================
# OTP and Auth
# ==============================
OTP_EXP="15m"
JWT_ACCESS_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"
ACCESS_TOKEN_EXP="15m"
REFRESH_TOKEN_EXP="7d"

# ==============================
# Email Delivery
# ==============================
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@mimedcare.com"
SMTP_PASS="replace-with-your-smtp-password"

# ==============================
# Optional OAuth Providers
# Leave blank to disable Google/Facebook login.
# ==============================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL=""

FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
FACEBOOK_CALLBACK_URL=""

# ==============================
# Optional Push Notifications (Firebase)
# Leave blank to disable push delivery.
# FIREBASE_PRIVATE_KEY should preserve escaped newlines: \\n
# ==============================
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ==============================
# External APIs
# ==============================
IP_STACK_API_KEY=""

# ==============================
# Admin Bootstrap
# Used by server/scripts/admin-bootstrap.ts
# ==============================
ADMIN_NAME="Mi MedCare Admin"
ADMIN_EMAIL="admin@mimedcare.com"
ADMIN_PASSWORD="replace-with-a-strong-password"
