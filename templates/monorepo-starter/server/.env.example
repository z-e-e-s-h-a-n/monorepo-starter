
# ==============================
# Mi MedCare Server
# ==============================
NODE_ENV="your-node-env"
APP_PORT="your-app-port"
APP_ENDPOINT="your-app-endpoint"
CORS_ORIGIN="your-cors-origins"
CLIENT_ENDPOINT="your-client-endpoint"
ADMIN_ENDPOINT="your-admin-endpoint"

# ==============================
# Database
# ==============================
# Example: postgresql://postgres:password@localhost:5432/care-sync
DB_URI="your-database-uri"

# ==============================
# Media Storage
# ==============================
CLOUDINARY_ROOT_FOLDER="your-cloudinary-root-folder"
CLOUDINARY_URL="your-cloudinary-url"

# ==============================
# OTP and Auth
# ==============================
OTP_EXP="your-otp-expiry"
ACCESS_TOKEN_EXP="your-access-token-expiry"
REFRESH_TOKEN_EXP="your-refresh-token-expiry"
JWT_ACCESS_SECRET="your-jwt-access-secret"
JWT_REFRESH_SECRET="your-jwt-refresh-secret"

# ==============================
# Email Delivery
# ==============================
SMTP_HOST="your-smtp-host"
SMTP_PORT="your-smtp-port"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"

# ==============================
# OAuth Providers
# ==============================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="your-google-callback-url"

# ==============================
# SMS / WhatsApp (Twilio)
# ==============================
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="your-twilio-phone-number"
TWILIO_WHATSAPP_NUMBER="your-twilio-whatsapp-number"

# ==============================
# External APIs
# ==============================
IP_STACK_API_KEY="your-ip-stack-api-key"

# ==============================
# Admin Bootstrap
# ==============================
ADMIN_NAME="your-admin-name"
ADMIN_EMAIL="your-admin-email"
ADMIN_PASSWORD="your-admin-password"
